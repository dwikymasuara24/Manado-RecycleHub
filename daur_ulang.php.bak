                    <div class="input-suffix-wrap">
                        <input type="text" id="berat_kg" name="berat_kg"
                               value="<?= htmlspecialchars($berat_kg_value) ?>"
                               placeholder="Contoh: 5 atau 2.5"
                               class="<?= in_array('berat_kg', $errors) ? 'error' : '' ?>"
                               autocomplete="off" inputmode="decimal">
                        <span class="input-suffix">KG</span>
                    </div>
                    <?php if (in_array('berat_kg', $errors)): ?>
                        <span class="error-msg">Berat sampah wajib diisi.</span>
                    <?php endif; ?>
                </div>
                <div class="field-wrap">
                    <label for="catatan">Catatan <span style="font-size:0.75rem;font-weight:600;text-transform:none;letter-spacing:0;color:var(--text-light)">(opsional)</span></label>
                    <textarea id="catatan" name="catatan"
                              placeholder="Catatan untuk tim kami, misal: akses jalan, lantai, dll."
                              rows="3"><?= htmlspecialchars($catatan_value) ?></textarea>
                </div>
            </div>

            <!-- ══ SUBMIT ══ -->
        </form>
    </div>
    <div class="card-footer">
        <button type="submit" form="singleForm" class="btn btn-submit btn-full">
            KIRIM PERMINTAAN ✓
        </button>
    </div>

</div>
<?php endif; ?>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    'use strict';
    if (document.getElementById('pickerMap') === null) return;

    var btnDetect  = document.getElementById('btnDetectGPS');
    var btnText    = document.getElementById('btnGPSText');
    var statusBox  = document.getElementById('gpsStatus');
    var statusIcon = document.getElementById('gpsStatusIcon');
    var statusTxt  = document.getElementById('gpsStatusText');
    var kdDisplay  = document.getElementById('koordinatDisplay');
    var kdLat      = document.getElementById('kdLat');
    var kdLng      = document.getElementById('kdLng');
    var kdAcc      = document.getElementById('kdAcc');
    var mapLink    = document.getElementById('gpsMapLink');
    var inpLat     = document.getElementById('latitude');
    var inpLng     = document.getElementById('longitude');
    var inpManual  = document.getElementById('koordinatManualFlag');

    var pickerMap = null, pickerMarker = null;

    var defaultCenter = [1.4748, 124.8421]; // Pusat Manado
    var defaultZoom   = 13;

    if (inpLat.value !== '' && inpLng.value !== '') {
        defaultCenter = [parseFloat(inpLat.value), parseFloat(inpLng.value)];
        defaultZoom   = 16;
    }

    pickerMap = L.map('pickerMap', { center: defaultCenter, zoom: defaultZoom });
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap', maxZoom: 19
    }).addTo(pickerMap);

    pickerMarker = L.marker(defaultCenter, {
        draggable: true,
        title: 'Seret pin ke lokasi penjemputan'
    });

    if (inpLat.value !== '' && inpLng.value !== '') {
        pickerMarker.addTo(pickerMap);
        renderKoordinat(parseFloat(inpLat.value), parseFloat(inpLng.value), null);
        setStatus('found', '✅', 'Koordinat sudah tersimpan.');
    }

    pickerMap.on('click', function (e) {
        var lat = e.latlng.lat, lng = e.latlng.lng;
        pickerMarker.setLatLng(e.latlng).addTo(pickerMap);
        setCoords(lat, lng, 1, 'Dipilih dari peta');
        setStatus('found', '✅', 'Lokasi dipilih dari peta.');
    });

    pickerMarker.on('dragend', function () {
        var pos = pickerMarker.getLatLng();
        setCoords(pos.lat, pos.lng, 1, 'Digeser pada peta');
        setStatus('found', '✅', 'Lokasi diperbarui dari peta.');
    });

    function setCoords(lat, lng, manual, accLabel) {
        inpLat.value    = lat.toFixed(8);
        inpLng.value    = lng.toFixed(8);
        inpManual.value = manual;
        renderKoordinat(lat, lng, accLabel);
    }

    function moveMapTo(lat, lng) {
        var pos = L.latLng(lat, lng);
        pickerMarker.setLatLng(pos).addTo(pickerMap);
        pickerMap.setView(pos, 17);
    }

    btnDetect.addEventListener('click', function () {
        if (!navigator.geolocation) {
            setStatus('denied', '🚫', 'Browser tidak mendukung GPS. Pilih lokasi di peta.');
            return;
        }
        setLoading(true);
        setStatus('detecting', '⏳', 'Mendeteksi lokasi Anda…');
        navigator.geolocation.getCurrentPosition(
            function (pos) {
                var lat = pos.coords.latitude, lng = pos.coords.longitude, acc = Math.round(pos.coords.accuracy);
                setCoords(lat, lng, 0, '±' + acc + ' m');
                moveMapTo(lat, lng);
                setStatus('found', '✅', 'Lokasi terdeteksi! Akurasi ±' + acc + ' meter.');
                setLoading(false, 'success');
            },
            function (err) {
                setLoading(false, 'fail');
                var msg = {1:'Akses lokasi ditolak.', 2:'Posisi tidak tersedia.', 3:'Waktu habis — coba lagi.'}[err.code] || 'GPS error.';
                setStatus('gps-failed', '⚠️', msg + ' Pilih lokasi langsung di peta.');
            },
            { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
        );
    });

    function renderKoordinat(lat, lng, acc) {
        kdLat.textContent = lat.toFixed(7);
        kdLng.textContent = lng.toFixed(7);
        kdAcc.textContent = acc !== null ? acc : '—';
        mapLink.href      = 'https://www.google.com/maps?q=' + lat + ',' + lng;
        kdDisplay.classList.add('show');
    }

    function setStatus(type, icon, text) {
        statusBox.className    = 'gps-status show ' + type;
        statusIcon.textContent = icon;
        statusTxt.textContent  = text;
    }

    function setLoading(isLoading, result) {
        btnDetect.disabled = isLoading;
        btnDetect.classList.toggle('loading', isLoading);
        if (isLoading) { btnText.textContent = 'Mendeteksi…'; return; }
        if (result === 'success') { btnDetect.classList.add('success'); btnText.textContent = 'Lokasi Terdeteksi ✓'; }
        else if (result === 'fail') {
            btnDetect.classList.add('gps-error'); btnText.textContent = 'Gagal — Coba Lagi';
            setTimeout(function () { btnDetect.classList.remove('gps-error'); btnText.textContent = 'Deteksi Lokasi Saya'; }, 3000);
        }
    }
})();
</script>

</body>
</html>
